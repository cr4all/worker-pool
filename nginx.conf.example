# Example nginx.conf fragment — aimed at nginx 1.24.x (stable/mainline packages).
# Typical paths:
#   Full file:     /etc/nginx/nginx.conf
#   Or include:    include /etc/nginx/conf.d/ultrasportsbot.conf;
#   Debian/Ubuntu: sites-enabled via symlink into sites-available.

worker_processes auto;

events {
    worker_connections 4096;
}

http {

    include       /etc/nginx/mime.types;
    # If this path does not exist (e.g. custom prefix), use: include mime.types;
    default_type  application/octet-stream;

    sendfile        on;
    tcp_nopush      on;
    keepalive_timeout  65;

    ########################################################
    # Host-based routing for noVNC (same pattern as worker-pool NOVNC_DOMAIN):
    #   https://web-6080.ultrasportsbot.com -> 127.0.0.1:6080
    #   https://web-6081.ultrasportsbot.com -> 127.0.0.1:6081
    ########################################################

    map $host $backend_port {

        # Allowed host port range: 6080 ~ 6200 (matches capture group $1)
        ~^web-(608[0-9]|609[0-9]|61[0-9]{2}|6200)\.ultrasportsbot\.com$ $1;

        default 0;
    }

    ########################################################
    # Main controller API (uvicorn / worker-pool)
    ########################################################

    server {
        listen 80;
        server_name ctrl.ultrasportsbot.com;

        location / {

            proxy_pass http://127.0.0.1:5000;

            proxy_http_version 1.1;

            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;

            proxy_set_header Upgrade    $http_upgrade;
            proxy_set_header Connection "upgrade";
        }
    }

    ########################################################
    # noVNC dynamic proxy (WebSocket + long-lived sessions)
    ########################################################

    server {

        listen 80;

        server_name ~^web-(608[0-9]|609[0-9]|61[0-9]{2}|6200)\.ultrasportsbot\.com$;

        # Disallow hostnames outside the map (invalid / unknown subdomain)
        if ($backend_port = 0) {
            return 403;
        }

        location / {

            proxy_pass http://127.0.0.1:$backend_port;

            proxy_http_version 1.1;

            # WebSocket (required for noVNC)
            proxy_set_header Upgrade    $http_upgrade;
            proxy_set_header Connection "upgrade";

            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;

            proxy_read_timeout  86400s;
            proxy_send_timeout  86400s;

            proxy_buffering off;
        }
    }
}
