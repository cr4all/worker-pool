## Copy to ".env" and edit values.
## Lines starting with '#' are comments.

# FastAPI listen port when you start the API with: python -m app.main
API_PORT=8080

# Optional. If set, all endpoints except /health require:
#   Authorization: Bearer <API_KEY>
API_KEY=

# VNC password for the Chromium VNC server inside the container.
VNC_PASS=mystakechrome

# Docker image to run for each Chrome instance.
# proxy-chrome:latest        — Alpine + Chromium (proxy-chromium-docker)
# proxy-google-chrome:latest — Ubuntu 22.04 + Google Chrome (proxy-chrome-docker)
CHROME_DOCKER_IMAGE=proxy-chrome:latest

# Optional. CSV path (Region,Host,Port,User,Pass). Missing or empty file = start Chrome without proxy env.
PROXIES_CSV=proxies.csv

# Seconds to wait for CDP to become ready after starting a container.
START_CDP_TIMEOUT_SEC=60

# Global max number of running pool containers.
# If unset/empty, it is auto-computed from total RAM:
#   max(1, floor(total_ram_bytes * 0.85 / 1GiB))
MAX_RUNNING=

# Optional. If set (e.g. serverbot.com), POST /start returns novnc_url:
#   https://web-<novnc_port>.<NOVNC_DOMAIN>/vnc.html?autoconnect=1&password=<url-encoded VNC password>
NOVNC_DOMAIN=

# --- Windows Server (native CDP mode; ignored on Linux/Docker) ---
# On Windows, the pool runs chrome.exe directly (no Docker/VNC/noVNC).
# CHROME_EXE_PATH is required on Windows.

# Full path to chrome.exe (required on Windows Server).
# CHROME_EXE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Run Chrome headless (default true on Windows). Set false for headed debugging via RDP.
CHROME_HEADLESS=true

# CDP: Chrome binds 127.0.0.1; the pool runs a TCP relay (0.0.0.0:<port> -> 127.0.0.1:<port>, no Administrator required).

# Optional per-instance profile root (default: %TEMP%\chrome-pool).
# CHROME_USER_DATA_ROOT=C:\Temp\chrome-pool
