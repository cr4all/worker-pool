{
    "manifest_version": 3,
    "name": "Auth",
    "version": "1.0.0",
    "description": "Build an Extension!",
    "permissions": [
    "proxy",
    "tabs",
    "unlimitedStorage",
    "storage",
    "webRequest",
    "webRequestAuthProvider"
    ],
    "host_permissions": [
    "*://*/*"
    ],
    "background": {
    "service_worker": "background.js"
    }
}
